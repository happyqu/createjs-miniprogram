{
  "name": "@happyqu/createjs-miniprogram",
  "version": "1.0.0",
  "description": "CreateJS (EaselJS and TweenJS) adapted for WeChat Mini Programs",
  "keywords": [
    "createjs",
    "easeljs",
    "tweenjs",
    "wechat",
    "weapp",
    "miniprogram",
    "canvas"
  ],
  "homepage": "https://github.com/happyqu/createjs-miniprogram#readme",
  "bugs": {
    "url": "https://github.com/happyqu/createjs-miniprogram/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happyqu/createjs-miniprogram.git"
  },
  "license": "MIT",
  "author": "happy",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "miniprogram": "./dist",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./tweenjs": {
      "types": "./dist/tweenjs.d.ts",
      "import": "./dist/tweenjs.mjs",
      "require": "./dist/tweenjs.js",
      "default": "./dist/tweenjs.mjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js",
      "default": "./dist/core.mjs"
    },
    "./text": {
      "types": "./dist/text.d.ts",
      "import": "./dist/text.mjs",
      "require": "./dist/text.js",
      "default": "./dist/text.mjs"
    },
    "./movieclip": {
      "types": "./dist/movieclip.d.ts",
      "import": "./dist/movieclip.mjs",
      "require": "./dist/movieclip.js",
      "default": "./dist/movieclip.mjs"
    },
    "./filters": {
      "types": "./dist/filters.d.ts",
      "import": "./dist/filters.mjs",
      "require": "./dist/filters.js",
      "default": "./dist/filters.mjs"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "import": "./dist/builder.mjs",
      "require": "./dist/builder.js",
      "default": "./dist/builder.mjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.mjs",
      "require": "./dist/ui.js",
      "default": "./dist/ui.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": true,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node scripts/build.cjs",
    "size": "node scripts/size-report.cjs",
    "check:size": "node scripts/size-report.cjs --check",
    "test": "npm run build && node scripts/check-browser-globals.cjs && node scripts/smoke-test.cjs && node scripts/core-smoke-test.cjs && npm run check:size",
    "prepublishOnly": "npm test && npm pack --dry-run"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18"
  }
}
