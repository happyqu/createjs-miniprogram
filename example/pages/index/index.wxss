page {
  min-height: 100%;
  background: #050b14;
  color: #ffffff;
}

.page-shell {
  min-height: 100vh;
  padding: 56rpx 28rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 82% 5%, rgba(51, 123, 255, 0.22), transparent 34%),
    #050b14;
}

.hero-copy {
  width: 690rpx;
  margin: 0 auto 30rpx;
}

.eyebrow {
  color: #62d7ff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.headline {
  margin-top: 14rpx;
  font-size: 52rpx;
  line-height: 1.15;
  font-weight: 750;
}

.description {
  margin-top: 16rpx;
  color: #8197b3;
  font-size: 26rpx;
  line-height: 1.65;
}

.canvas-card {
  position: relative;
  width: 690rpx;
  height: 760px;
  margin: 0 auto;
  overflow: hidden;
  border: 1rpx solid rgba(125, 224, 255, 0.20);
  border-radius: 32rpx;
  background: transparent;
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.42);
}

.demo-canvas {
  width: 100%;
  height: 100%;
  display: block;
  overflow: hidden;
  border-radius: 32rpx;
}

.loading {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8ca6c4;
  font-size: 26rpx;
  background: #081426;
  border-radius: 32rpx;
}

.cache-button {
  width: 690rpx;
  height: 92rpx;
  margin: 28rpx auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(98, 215, 255, 0.42);
  border-radius: 24rpx;
  color: #06111f;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #69e6ff, #5b8cff);
  box-shadow: 0 16rpx 42rpx rgba(51, 123, 255, 0.22);
}

.cache-button::after {
  border: 0;
}

.cache-button.is-cached {
  color: #dff8ff;
  border-color: rgba(125, 224, 255, 0.28);
  background: rgba(28, 62, 94, 0.72);
  box-shadow: none;
}

.cache-button[disabled] {
  opacity: 0.45;
}

.cache-status {
  width: 650rpx;
  margin: 16rpx auto 0;
  color: #647c98;
  font-size: 21rpx;
  line-height: 1.55;
  text-align: center;
}

.benchmark-link {
  width: 690rpx;
  margin: 22rpx auto 0;
  color: #62d7ff;
  font-size: 25rpx;
  text-align: center;
}

.stats {
  width: 690rpx;
  margin: 28rpx auto 0;
  padding: 26rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.035);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  color: #eaf6ff;
  font-size: 27rpx;
  font-weight: 700;
}

.stat-label {
  color: #647c98;
  font-size: 21rpx;
}

.divider {
  width: 1rpx;
  height: 54rpx;
  background: rgba(255, 255, 255, 0.10);
}
