page { background: #07101d; color: #dff6ff; }
.page { min-height: 100vh; padding: 32rpx; box-sizing: border-box; }
.title { font-size: 38rpx; font-weight: 700; margin-bottom: 24rpx; }
.controls { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.controls button { margin: 0; color: #06111f; background: #67dffc; }
.canvas { width: 686rpx; height: 720rpx; border: 1rpx solid #24506e; background: #02060b; }
.metrics { margin-top: 24rpx; padding: 24rpx; font: 26rpx/1.8 monospace; border-radius: 16rpx; background: #0e2034; }
