<view class="page">
  <view class="title">CreateJS Phase 3 Benchmark</view>
  <view class="controls">
    <button size="mini" data-test="bitmap" bindtap="runTest">1000 静态</button>
    <button size="mini" data-test="moving" bindtap="runTest">100 移动</button>
    <button size="mini" data-test="movieclip" bindtap="runTest">MovieClip</button>
  </view>
  <button class="phase-toggle" size="mini" bindtap="togglePhase3">Phase 3：{{phase3 ? '开启' : '关闭'}}</button>
  <canvas id="benchmarkCanvas" type="2d" class="canvas"></canvas>
  <view class="metrics">
    <view>场景：{{testName}}</view>
    <view>FPS：{{fps}}</view>
    <view>更新：{{updateTime}} ms</view>
    <view>渲染：{{renderTime}} ms</view>
    <view>绘制数：{{drawCount}}</view>
    <view>显示对象：{{displayObjectCount}}</view>
    <view>首屏：{{firstPaint}} ms</view>
    <view>内存：{{memory}}</view>
    <view>脏矩形：{{dirtyRect}}</view>
    <view>全量渲染：{{fullRender}}</view>
    <view>自动缓存：{{cacheObject}}</view>
    <view>跳过对象：{{skippedObjects}}</view>
    <view>Bitmap 批次：{{bitmapBatches}}</view>
    <view>编译渲染：{{compiledRender}}</view>
    <view>渲染命令：{{commandCount}}</view>
    <view>Canvas 调用：{{canvasCalls}}</view>
    <view>离屏复用池：{{offscreenSurfaces}}</view>
  </view>
</view>
